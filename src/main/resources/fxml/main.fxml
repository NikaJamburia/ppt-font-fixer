<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="15"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ge.nika.pptfontfixer.controller.MainController">
    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="მარი, აირჩიე ფაილი და დააჭირე დაწყებას" style="-fx-font-size: 16px;"/>

    <Button text="ფაილის არჩევა" onAction="#selectFile" prefWidth="200"/>

    <Label fx:id="fileNameLabel" text="" style="-fx-font-size: 12px; -fx-text-fill: #555;"/>

    <Button text="დაწყება" onAction="#startProcessing" prefWidth="200" style="-fx-font-size: 14px;"/>

    <Label fx:id="statusLabel" text="" style="-fx-font-size: 12px;"/>

    <ProgressIndicator fx:id="progressIndicator" visible="false" prefWidth="40" prefHeight="40"/>
</VBox>
